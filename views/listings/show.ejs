<% layout("/layouts/boilerplate") %>

<div class="row mt-3">

<div class="col-8 offset-3 mb-3">
<h3><%= listing.title %></h3>
</div>

<div class="card col-6 offset-3 show-card listing-card">
<img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">

<div class="card-body" style="background-color:#f9f9f9; padding:20px; border-radius:10px;">
<h3 style="font-weight:600; color:#1c1c1c"><%= listing.title %></h3>

<p style="color:#555; font-size:1rem"><%= listing.description %></p>

<p><b>Owner:</b> <%= listing.owner.username %></p>

<p><b>Location:</b> <%= listing.location %>, <%= listing.country %></p>

<p><b>Price:</b> ₹<%= listing.price.toLocaleString("en-IN") %></p>

</div>
</div>


<% if(currUser && listing.owner._id.equals(currUser._id)){ %>

<div class="btns">

<a href="/listings/<%=listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">
Edit
</a>

<form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
<button class="btn btn-dark offset-5">Delete</button>
</form>

</div>

<% } %>


<div class="col-6 offset-3 mt-3">

<h3>Book this stay</h3>

<% if(currUser){ %>

<div class="booking-form">

    <label>Check-in Date</label>
    <input type="text" id="checkIn" class="form-control mb-2">

    <label>Check-out Date</label>
    <input type="text" id="checkOut" class="form-control mb-3">


    <div id="priceDetails" class="mt-3 p-3 border rounded" style="background:#f8f9fa;">
    <p>₹<span id="pricePerNight"><%= listing.price %></span> × 
    <span id="nights">0</span> nights</p>

    <p>Subtotal: ₹<span id="subtotal">0</span></p>

    <p>Taxes: ₹<span id="taxes">0</span></p>

    <hr>

    <h5>Total: ₹<span id="total">0</span></h5>
    </div>    





    <form method="POST" action="/bookings/<%= listing._id %>" onsubmit="setDates()">
        <input type="hidden" name="checkIn" id="hiddenCheckIn">
        <input type="hidden" name="checkOut" id="hiddenCheckOut">
        <input type="hidden" name="totalPrice" id="hiddenTotal">

        <button class="btn btn-danger w-100">Pay Now</button>
    </form>

</div>

<% } else { %>

<p>Please <a href="/login">login</a> to book this stay</p>

<% } %>

</div>

