<% layout("/layouts/boilerplate") %>

<h2 class="mb-4"><b>My Bookings</b></h2>

<div class="row">
  <% if (bookings.length === 0) { %>
    <h4 class="text-center mt-5">No confirmed bookings yet 😔</h4>
  <% } %>
<% bookings.forEach(booking => { %>

<div class="col-md-4 mb-4">
<div class="card">
  <div class="card-body">
    <% if(booking.listing){ %>
      <h5 class="card-title"><%= booking.listing.title %></h5>
    <% } else { %>
      <h5 class="card-title text-danger">Listing Deleted</h5>
    <% } %>

  <p class="card-text">
    <b>Check-in:</b> 
    <%= booking.checkIn ? new Date(booking.checkIn).toDateString() : "N/A" %><br>

    <b>Check-out:</b> 
    <%= booking.checkOut ? new Date(booking.checkOut).toDateString() : "N/A" %><br>

    <b>Total Price:</b> ₹ <%= booking.totalPrice %>
  </p>
    <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST" >
      <button class="btn btn-danger  ">Cancel Booking</button>
    </form>

  </div>
</div>
</div>

<% }) %>

</div>

